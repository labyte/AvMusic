<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvMusic.ViewModels"
             xmlns:controls="using:AvMusic.Controls"
             xmlns:ui="using:AvMusic.Ui"
             xmlns:views="using:AvMusic.Views"
             x:Class="AvMusic.Views.QueueDrawerView"
             x:DataType="vm:PlayerViewModel"
             Background="Transparent">
  <!-- 单列叠加：遮罩铺满，面板浮于右侧，避免右侧列露出白底 -->
  <Panel Background="Transparent">
    <Button Classes="ghost-button queue-drawer-backdrop"
            Background="#66000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Command="{Binding CloseQueueDrawerCommand}"
            Cursor="Arrow"/>

    <Panel Width="400"
           Margin="0,56,16,48"
           HorizontalAlignment="Right"
           VerticalAlignment="Stretch"
           Background="Transparent">
      <!-- 阴影层（透明底，不裁剪投影） -->
      <Border Classes="queue-drawer-shadow"
              Background="Transparent"
              CornerRadius="12"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"/>
      <!-- 内容层：边框 + 圆角，内部裁剪 -->
      <Border Classes="queue-drawer-panel"
              CornerRadius="12"
              ClipToBounds="True"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
        <Grid RowDefinitions="Auto,*">
          <Grid Grid.Row="0" Margin="20,20,20,12" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
              <TextBlock Text="播放列表" FontSize="18" FontWeight="Bold"/>
              <TextBlock Text="{Binding QueueCountText}"
                         FontSize="11"
                         Opacity="0.45"
                         VerticalAlignment="Top"
                         Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
              <Button Classes="queue-header-action" Command="{Binding FavoriteAllQueueCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <controls:AppIcon Kind="{x:Static ui:AppIconKind.PlaylistAdd}" IconSize="16"/>
                  <TextBlock Text="收藏全部" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
              <Button Classes="queue-header-action" Command="{Binding ClearQueueCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <controls:AppIcon Kind="{x:Static ui:AppIconKind.Trash}" IconSize="16"/>
                  <TextBlock Text="清空" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Margin="12,0,12,12"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding QueueRows}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:QueueRowViewModel">
                  <views:QueueRowView/>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
    </Panel>
  </Panel>
</UserControl>
