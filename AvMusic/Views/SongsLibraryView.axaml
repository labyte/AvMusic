<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvMusic.ViewModels.Library"
             x:Class="AvMusic.Views.SongsLibraryView"
             x:DataType="vm:SongsLibraryViewModel">
  <Grid RowDefinitions="Auto,*,Auto">
    <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Foreground="IndianRed" Margin="8,0"
               IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
    <ListBox Grid.Row="1" ItemsSource="{Binding SongRows}" Margin="8">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="vm:SongRowViewModel">
          <Button Command="{Binding PlayCommand}" Classes="ghost-button"
                  HorizontalContentAlignment="Stretch" Padding="8,6">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Subtitle}" Opacity="0.7" FontSize="12"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding DurationText}" Opacity="0.5" VerticalAlignment="Center"/>
            </Grid>
          </Button>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="8">
      <Button Content="加载更多" Command="{Binding LoadMoreCommand}" IsVisible="{Binding HasMore}"/>
      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Width="120"/>
    </StackPanel>
  </Grid>
</UserControl>
