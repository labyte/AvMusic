<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvMusic.ViewModels"
             x:Class="AvMusic.Views.PlayerBarView"
             x:DataType="vm:PlayerViewModel"  Margin="0">
  <Grid RowDefinitions="Auto *">
       <Grid ColumnDefinitions="Auto,*,Auto" Margin="4 0">
          <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
          <Slider x:Name="SeekSlider" Grid.Column="1" Background="Red"
                  Minimum="0" Maximum="{Binding SeekMaximum}"
                  Value="{Binding Position, Mode=TwoWay}"
                  IsEnabled="{Binding CanSeek}"/>
          <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
        </Grid>
    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
      <!-- 封面缩略图，点击打开全屏 -->
      <Button Grid.Column="0" Command="{Binding ShowNowPlayingCommand}"
              Width="48" Height="48" Padding="0" Background="Transparent">
        <Border Width="48" Height="48" CornerRadius="4" ClipToBounds="True"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
          <Panel>
            <Image Source="{Binding Cover}" Stretch="UniformToFill"
                   IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            <TextBlock Text="♪" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsVisible="{Binding Cover, Converter={x:Static ObjectConverters.IsNull}}"/>
            <Border Background="#66000000" IsVisible="{Binding IsLoading}">
              <ProgressBar IsIndeterminate="True" Width="20" Height="20"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Panel>
        </Border>
      </Button>

      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
        <Button Content="⏮" Command="{Binding PreviousCommand}" ToolTip.Tip="上一首"/>
        <Button Content="⏯" Command="{Binding PlayPauseCommand}" ToolTip.Tip="播放/暂停"/>
        <Button Content="⏭" Command="{Binding NextCommand}" ToolTip.Tip="下一首"/>
      </StackPanel>

      <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center" Margin="0,0,8,0">
        <Button Command="{Binding ShowNowPlayingCommand}" Background="Transparent"
                HorizontalContentAlignment="Stretch" Padding="0">
          <StackPanel Spacing="0">
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding Subtitle}" Opacity="0.7" FontSize="11" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Button>
       
      </StackPanel>

      <Button Grid.Column="3" Content="{Binding FavoriteIcon}" Command="{Binding ToggleFavoriteCommand}"
              ToolTip.Tip="喜欢" FontSize="18" VerticalAlignment="Center"/>
    </Grid>
  </Grid>
</UserControl>
