<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvMusic.ViewModels.Library"
             xmlns:models="using:AvMusic.Core.Models"
             x:Class="AvMusic.Views.SearchLibraryView"
             x:DataType="vm:SearchLibraryViewModel">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8">
      <TextBox Width="280" Watermark="输入关键词" Text="{Binding Keyword}"/>
      <Button Content="搜索" Command="{Binding SearchCommand}"/>
    </StackPanel>
    <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="IndianRed" Margin="8,0"
               IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>
    <ScrollViewer Grid.Row="2" Margin="8">
      <StackPanel Spacing="16">
        <StackPanel Spacing="4">
          <TextBlock Text="歌曲" FontWeight="SemiBold"/>
          <ListBox ItemsSource="{Binding SongRows}" MaxHeight="300">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:SongRowViewModel">
                <Button Command="{Binding PlayCommand}" Background="Transparent"
                        HorizontalContentAlignment="Stretch" Padding="6,4">
                  <TextBlock Text="{Binding Title}"/>
                </Button>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="专辑" FontWeight="SemiBold"/>
          <ItemsControl ItemsSource="{Binding Albums}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Album">
                <TextBlock Text="{Binding Name}" Margin="0,2"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
        <StackPanel Spacing="4">
          <TextBlock Text="艺术家" FontWeight="SemiBold"/>
          <ItemsControl ItemsSource="{Binding Artists}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:Artist">
                <TextBlock Text="{Binding Name}" Margin="0,2"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
    <ProgressBar Grid.Row="3" IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="4" Margin="8"/>
  </Grid>
</UserControl>
