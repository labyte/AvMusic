<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AvMusic.ViewModels"
             xmlns:views="using:AvMusic.Views"
             xmlns:controls="using:AvMusic.Controls"
             xmlns:ui="using:AvMusic.Ui"
             xmlns:conv="using:AvMusic.Converters"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AvMusic.Views.HomeView"
             x:DataType="vm:MainViewModel">
  <Grid RowDefinitions="*,Auto" RowSpacing="0">
    <Grid Grid.Row="0" ColumnDefinitions="200,*"   Margin="0,0,0,-4">
      <!-- 左侧导航 -->
      <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
              BorderThickness="0,0,1,0" Padding="8">
        <DockPanel LastChildFill="True">
          <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="AvMusic" FontSize="20" FontWeight="Bold" Margin="8,4"/>
            <Button Classes="nav-button" Command="{Binding LogoutCommand}" HorizontalAlignment="Stretch">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.SignOut}" IconSize="18"/>
                <TextBlock Text="退出登录" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>

          <StackPanel Spacing="4">
            <Button Classes="nav-button"
                    Classes.selected="{Binding Library.ActiveNavKey, Converter={x:Static conv:NavSelectedConverter.Instance}, ConverterParameter='songs'}"
                    Command="{Binding Library.NavigateCommand}" CommandParameter="songs">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.MusicNote}" IconSize="18"/>
                <TextBlock Text="全部歌曲" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="nav-button"
                    Classes.selected="{Binding Library.ActiveNavKey, Converter={x:Static conv:NavSelectedConverter.Instance}, ConverterParameter='albums'}"
                    Command="{Binding Library.NavigateCommand}" CommandParameter="albums">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.Album}" IconSize="18"/>
                <TextBlock Text="专辑" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="nav-button"
                    Classes.selected="{Binding Library.ActiveNavKey, Converter={x:Static conv:NavSelectedConverter.Instance}, ConverterParameter='artists'}"
                    Command="{Binding Library.NavigateCommand}" CommandParameter="artists">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.Artist}" IconSize="18"/>
                <TextBlock Text="艺术家" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="nav-button"
                    Classes.selected="{Binding Library.ActiveNavKey, Converter={x:Static conv:NavSelectedConverter.Instance}, ConverterParameter='folders'}"
                    Command="{Binding Library.NavigateCommand}" CommandParameter="folders">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.Folder}" IconSize="18"/>
                <TextBlock Text="文件夹" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="nav-button"
                    Classes.selected="{Binding Library.ActiveNavKey, Converter={x:Static conv:NavSelectedConverter.Instance}, ConverterParameter='genres'}"
                    Command="{Binding Library.NavigateCommand}" CommandParameter="genres">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.Tag}" IconSize="18"/>
                <TextBlock Text="类型" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Classes="nav-button"
                    Classes.selected="{Binding Library.ActiveNavKey, Converter={x:Static conv:NavSelectedConverter.Instance}, ConverterParameter='search'}"
                    Command="{Binding Library.NavigateCommand}" CommandParameter="search">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <controls:AppIcon Kind="{x:Static ui:AppIconKind.Search}" IconSize="18"/>
                <TextBlock Text="搜索" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- 内容区 -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="16,12,16,8">
          <controls:IconButton Classes="text-button"
                               Icon="{x:Static ui:AppIconKind.ChevronLeft}"
                               Command="{Binding Library.GoBackCommand}"
                               IsVisible="{Binding Library.CanGoBack}"
                               ToolTip.Tip="返回"/>
          <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"
                     Text="{Binding Library.CurrentPageTitle}"/>
        </StackPanel>
        <ContentControl Grid.Row="1" Margin="8,0,8,8" Content="{Binding Library.CurrentPage}"/>
      </Grid>
    </Grid>

    <views:PlayerBarView Grid.Row="1" DataContext="{Binding PlayerUi}"/>

    <Panel Grid.Row="0" IsVisible="{Binding PlayerUi.IsQueueDrawerOpen}" ZIndex="90" Background="Transparent">
      <views:QueueDrawerView DataContext="{Binding PlayerUi}"/>
    </Panel>

    <Panel Grid.Row="0" Grid.RowSpan="2" IsVisible="{Binding PlayerUi.IsNowPlayingVisible}" ZIndex="100">
      <views:NowPlayingView DataContext="{Binding PlayerUi}"/>
    </Panel>
  </Grid>
</UserControl>
